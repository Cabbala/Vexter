# Edit on win-lan at:
#   C:\Users\bot\quant\Vexter\sources\Dexter\.env
#
# This template is reference-only. Dexter reads the repo-root `.env` file
# via `DexLab/common_.py`, and its PostgreSQL DSN stays hardcoded to:
#   postgres://dexter_user:admin123@127.0.0.1/dexter_db

PRIVATE_KEY=
# Must be a base58 Solana signing key. Do not reuse the Helius `api-key`
# value from HTTP_URL or WS_URL here.
HTTP_URL=https://mainnet.helius-rpc.com/?api-key=
WS_URL=wss://mainnet.helius-rpc.com/?api-key=

VEXTER_RUNTIME_ROOT=C:\Users\bot\quant\Vexter
VEXTER_OUTPUT_ROOT=C:\Users\bot\quant\Vexter
# Dexter defaults to `observe_live` internally, but Vexter paper validation
# should set the explicit comparison-safe `paper_live` path.
VEXTER_MODE=paper_live
VEXTER_TRANSPORT_MODE=ws

# Bounded demo executor adapter references. Keep actual venue credentials and
# broker secrets outside repo-tracked strategy semantics; these are references
# and guardrails only.
DEXTER_DEMO_CREDENTIAL_SOURCE=external_reference
DEXTER_DEMO_VENUE_REF=dexter_paper_live_demo_venue
DEXTER_DEMO_ACCOUNT_REF=dexter_paper_live_demo_account
DEXTER_DEMO_CONNECTIVITY_PROFILE=dexter_paper_live_demo_connectivity
DEXTER_DEMO_ALLOWED_SYMBOLS=BONK/USDC
DEXTER_DEMO_DEFAULT_SYMBOL=BONK/USDC
DEXTER_DEMO_ORDER_SIZE_LOTS=0.05
DEXTER_DEMO_MAX_ORDER_SIZE_LOTS=0.05
DEXTER_DEMO_WINDOW_MINUTES=15
DEXTER_DEMO_MAX_OPEN_POSITIONS=1

# Optional: pin a custom run id for matched-window collection.
# VEXTER_RUN_ID=dexter-20260321-window-a
