# Edit on win-lan at:
#   C:\Users\bot\quant\Vexter\sources\Dexter\.env
#
# This template is reference-only. Dexter reads the repo-root `.env` file
# via `DexLab/common_.py`, and its PostgreSQL DSN stays hardcoded to:
#   postgres://dexter_user:admin123@127.0.0.1/dexter_db

PRIVATE_KEY=""
HTTP_URL="https://mainnet.helius-rpc.com/?api-key="
WS_URL="wss://mainnet.helius-rpc.com/?api-key="

VEXTER_RUNTIME_ROOT="C:\\Users\\bot\\quant\\Vexter"
VEXTER_OUTPUT_ROOT="C:\\Users\\bot\\quant\\Vexter"
VEXTER_MODE="observe_live"
VEXTER_TRANSPORT_MODE="ws"

