# Edit on win-lan at:
#   C:\Users\bot\quant\Vexter\sources\Mew-X\.env
#
# This template captures the minimum user-owned secrets and runtime knobs
# needed for TASK-005 live collection. Keep real secrets out of git.

PRIVATE_KEY=""
# Must be a base58 Solana signing key. Do not reuse the Helius `api-key`
# value from RPC_URL or WS_URL here.
RPC_URL="https://mainnet.helius-rpc.com/?api-key="
WS_URL="wss://mainnet.helius-rpc.com/?api-key="
DB_URL="postgres://postgres:admin123@127.0.0.1:5432"

USE_GRPC=false
GRPC_URL=""
GRPC_TOKEN=""
NONCE_ACCOUNT=""

MODE="trade"
MAX_TOKENS_AT_ONCE=1
TX_STRAT="swqos"
NEXTBLOCK_KEY=""
ZERO_SLOT_KEY=""
TEMPORAL_KEY=""
BLOX_KEY=""
TIP_SOL=0.001
PRIORITY_FEE_LVL="medium"
USE_REGIONS=false
REGIONS="Germany, Netherlands, United Kingdom"

VEXTER_RUNTIME_ROOT="C:\\Users\\bot\\quant\\Vexter"
VEXTER_OUTPUT_ROOT="C:\\Users\\bot\\quant\\Vexter"

# Optional: pin a custom run id for matched-window collection.
# VEXTER_RUN_ID="mewx-20260321-window-a"
